# dbt Semantic Layer Configuration (required for non-MCP strategies)
SL_URL=semantic-layer.emea.dbt.com
ENVIRONMENT_ID=your_environment_id_here
DBT_SL_SERVICE_TOKEN=your_service_token_here

# ============================================================================
# MCP Server Configuration
# ============================================================================

# Server type: "http" for remote, "stdio" for local process
MCP_SERVER_TYPE=http

# --- HTTP (Remote) Server Configuration ---
# Required when MCP_SERVER_TYPE=http
MCP_HTTP_URL=https://emea.dbt.com/api/ai/v1/mcp/
# Note: Authorization and environment ID headers are automatically added
# from DBT_SL_SERVICE_TOKEN and ENVIRONMENT_ID above

# --- Stdio (Local) Server Configuration ---
# Required when MCP_SERVER_TYPE=stdio
# Example: Using uvx to run dbt MCP server locally
# MCP_SERVER_TYPE=stdio
# MCP_STDIO_COMMAND=uvx
# MCP_STDIO_ARGS=["mcp-server-dbt", "--manifest-path", "./target/manifest.json"]

# --- Common Configuration ---
MCP_TIMEOUT=60
# MCP_TOOL_PREFIX=  # Optional prefix for all MCP tool names
